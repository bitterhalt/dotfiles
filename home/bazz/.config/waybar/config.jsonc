// SETTINGS
{
  "layer": "top",
  "position": "top",
  // "height": 32,
  "spacing": 4,
  "modules-left": ["niri/workspaces", "niri/window"],
  "modules-center": ["group/middle", "privacy", "custom/wf-recorder"],
  "modules-right": [
    "group/connections",
    "pulseaudio",
    "custom/idle",
    "battery",
    "group/hidden-tray",
  ],

  // NIRI MODULES
  "niri/workspaces": {
    "disable-scroll": true,
  },

  "niri/window": {
    "format": "{}",
    "icon": true,
    "icon-size": 20,
    "max-length": 70,
    "separate-outputs": true,
    "tooltip": false,
  },

  // TRAY
  "tray": {
    "icon-size": 20,
    "spacing": 12,
    "icons": {
      // Override some ugly icons
      "discord": "discord",
    },
  },

  // BATTERY
  "battery": {
    "bat": "BAT0",
    "interval": 60,
    "states": {
      "warning": 30,
      "critical": 15,
    },
    "format": "{capacity}% {icon}",
    "format-icons": ["蟀値", "蟀伜", "蟀伝", "蟀伡", "蟀伣", "蟀伨", "蟀伩", "蟀個", "蟀倎", "蟀倐", "蟀伖"],
    "max-length": 25,
  },

  // NETWORK
  "network": {
    "format-disconnected": "蟀厸",
    "format-ethernet": "蟀垁",
    "format-linked": "{ifname} (No IP) ?",
    "format-wifi": "蟀柀",
    "max-length": 30,
    "on-click": "nm-connection-editor",
    "tooltip-format": "{ifname} via {gwaddr}",
    "tooltip-format-disconnected": "Disconnected",
    "tooltip-format-wifi": "Network: <b>{essid}</b>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>",
  },

  // BLUETOOTH
  "bluetooth": {
    "format": "蟀偗",
    "format-connected": "蟀偗",
    "format-disabled": "",
    "on-click": "foot -a bluetui -e bluetui",
    "tooltip-format": "{num_connections} connected",
    "tooltip-format-connected": "[ {num_connections} ] connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_battery_percentage}%",
  },

  // AUDIO
  "pulseaudio": {
    "format": "{icon}",
    "format-icons": ["蟀暱", "蟀杸", "蟀杸", "蟀暰"],
    "format-muted": "蟀潫",
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "scroll-step": 5,
    "tooltip-format": "Vol:\t{volume}%",
  },

  // CLOCK
  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "{:%a, <b>%d</b>, %b %Y}",
  },
  // "in case tzdata update fucks up your clock",
  "custom/clock": {
    "exec": "date +'%b %d %H:%M'",
    "format": "{}",
    "interval": 60,
    "tooltip": false,
  },

  // PRIVACY
  "privacy": {
    "icon-spacing": 2,
    "icon-size": 16,
    "transition-duration": 0,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 24,
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 24,
        "icon-name": "audio-input-microphone-symbolic",
      },
      {
        "type": "location",
        "tooltip": true,
        "tooltip-icon-size": 24,
        "icon-name": "location-services-active-symbolic",
      },
    ],
    "ignore-monitor": true,
    "ignore": [
      {
        "type": "audio-in",
        "name": "cava",
      },
      {
        "type": "screenshare",
        "name": "obs",
      },
    ],
  },

  // WEATHER
  "custom/weather": {
    "format": "{}",
    "tooltip": true,
    "interval": 3600,
    "return-type": "json",
    "exec": "~/.config/waybar/scripts/weather.sh",
  },

  // INDICATORS
  "custom/idle": {
    "exec": "~/.config/waybar/scripts/idle.sh",
    "format": "{}",
    "interval": "once",
    "on-click": "idle.sh -t; pkill -RTMIN+1 waybar",
    "return-type": "json",
    "signal": 1,
  },
  "custom/wf-recorder": {
    "exec": "echo '{\"class\": \"recording\",\"text\":\"蟀憢\",\"tooltip\":\"<b>Click:</b> to stop recording\"}'",
    "exec-if": "pgrep -f gpu-screen-recorder",
    "format": "{}",
    "interval": "once",
    "on-click": "~/.local/bin/wl-record -k",
    "return-type": "json",
    "signal": 2,
  },
  "custom/mako": {
    "exec": "~/.config/waybar/scripts/mako-helper.sh",
    "format": "{text}",
    "interval": 60,
    "on-click": "foot -T 'Mako History' -e mako_hist.py",
    "on-click-right": "makoctl mode -t dnd; pkill -RTMIN+3 waybar",
    "on-click-middle": "pkill mako; mako & sleep 0.2 && pkill -RTMIN+3 waybar",
    "return-type": "json",
    "signal": 3,
    "tooltip-format": "<b>Mako History</b><small>\n\n<b>Click:</b> Shows history\n\n<b>Click-right:</b> Toggles DND\n\n<b>Click-middle:</b> Wipes history</small>",
  },

  // SEPARATORS
  "custom/center-sep": {
    "format": "蟀嚈",
    "tooltip": false,
  },
  "custom/right-sep": {
    "format": "蟀嚈",
    "tooltip": false,
  },

  // GROUPS
  "group/middle": {
    "orientation": "inherit",
    "drawer": {
      "click-to-reveal": false,
      "transition-duration": 300,
    },
    "modules": ["clock", "custom/center-sep", "custom/mako", "custom/weather"],
  },
  "group/connections": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
    },
    "modules": ["network", "bluetooth"],
  },
  "group/hidden-tray": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
    },
    "modules": ["custom/right-sep", "tray"],
  },
}
