// SETTINGS
{
  "layer": "top",
  "position": "top",
  // "height": 32,
  "spacing": 4,
  "modules-left": ["niri/workspaces", "niri/window"],
  "modules-center": ["group/clock", "custom/wf-recorder"],
  "modules-right": [
    "network",
    "bluetooth",
    "group/audio",
    "custom/idle",
    "battery",
    "group/hidden-tray",
  ],

  // NIRI MODULES
  "niri/workspaces": {
    "disable-scroll": true,
  },

  "niri/window": {
    "format": "{}",
    "icon": true,
    "icon-size": 20,
    "max-length": 70,
    "separate-outputs": true,
    "tooltip": false,
  },

  // TRAY
  "tray": {
    "icon-size": 20,
    "spacing": 12,
    "icons": {
      // Override some ugly icons
      "discord": "discord",
    },
  },

  // BATTERY
  "battery": {
    "bat": "BAT0",
    "interval": 60,
    "states": {
      "warning": 30,
      "critical": 15,
    },
    "format": "{capacity}% {icon}",
    "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
    "max-length": 25,
  },

  // NETWORK
  "network": {
    "format-disconnected": "󰅛",
    "format-ethernet": "", // No icons needed if ethernet is connected
    "format-linked": "{ifname} (No IP) ?",
    "format-wifi": "󰖩",
    "max-length": 30,
    "on-click": "nm-connection-editor",
    "tooltip-format": "{ifname} via {gwaddr}",
    "tooltip-format-disconnected": "Disconnected",
    "tooltip-format-wifi": "Network: <b>{essid}</b>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>",
  },

  // AUDIO
  "pulseaudio#output": {
    "format": "{icon}",
    "format-icons": ["󰕿", "󰖀", "󰖀", "󰕾"],
    "format-muted": "󰝟",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "scroll-step": 5,
    "tooltip-format": "<b>{desc}</b>\t{volume}%",
  },
  "pulseaudio#input": {
    "format": "{format_source}",
    "format-source": "󰍬",
    "format-source-bluetooth": "󰍬",
    "format-source-bluetooth-muted": "󰍭",
    "format-source-muted": "󰍭",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
    "on-click-right": "pavucontrol",
    "tooltip": false,
  },

  // BLUETOOTH
  "bluetooth": {
    "format": "",
    "format-connected": "󰂯",
    "format-disabled": "",
    "on-click": "foot -a bluetui -e bluetui",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_battery_percentage}%",
  },

  // CLOCK
  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "{:%a, <b>%d</b>, %b %Y}",
  },
  // "in case tzdata update fucks up your clock",
  "custom/clock": {
    "exec": "date +'%b %d %H:%M'",
    "format": "{}",
    "interval": 60,
    "tooltip": false,
  },

  // WEATHER
  "custom/weather": {
    "exec": "wttrbar --date-format '%d/%m'", // Uses: https://github.com/bjesus/wttrbar
    "format": "{}°",
    "interval": 3600,
    "return-type": "json",
    "tooltip": true,
  },

  // INDICATORS
  "custom/idle": {
    "exec": "~/.config/waybar/scripts/idle.sh",
    "format": "{}",
    "interval": "once",
    "on-click": "idle.sh -t; pkill -RTMIN+1 waybar",
    "return-type": "json",
    "signal": 1,
  },
  "custom/wf-recorder": {
    "exec": "echo '{\"class\": \"recording\",\"text\":\"󰑋\",\"tooltip\":\"<b>Click:</b> to stop recording\"}'",
    "exec-if": "pgrep -f gpu-screen-recorder",
    "format": "{}",
    "interval": "once",
    "on-click": "~/.local/bin/wl-record -k",
    "return-type": "json",
    "signal": 2,
  },
  "custom/mako": {
    "exec": "~/.config/waybar/scripts/mako-helper.sh",
    "format": "{text}",
    "interval": 60,
    "on-click": "footclient -T 'Mako History' -e mako_hist.py",
    "on-click-right": "makoctl mode -t dnd; pkill -RTMIN+3 waybar",
    "on-click-middle": "pkill mako; mako & sleep 0.2 && pkill -RTMIN+3 waybar",
    "return-type": "json",
    "signal": 3,
    "tooltip-format": "<b>Mako History</b><small>\n\n<b>Click:</b> Shows history\n\n<b>Click-right:</b> Toggles DND\n\n<b>Click-middle:</b> Wipes history</small>",
  },

  // SEPARATORS
  "custom/center-sep": {
    "format": "󰇙",
    "tooltip": false,
  },
  "custom/right-sep": {
    "format": "󰇙",
    "tooltip-format": "Show/hide system tray",
  },

  // GROUPS
  "group/clock": {
    "orientation": "inherit",
    "drawer": {
      "click-to-reveal": false,
      "transition-duration": 300,
    },
    "modules": ["clock", "custom/mako", "custom/center-sep", "custom/weather"],
  },
  "group/audio": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
    },
    "modules": ["pulseaudio#output", "pulseaudio#input"],
  },
  "group/hidden-tray": {
    "orientation": "inherit",
    "drawer": {
      "click-to-reveal": true,
      "transition-duration": 300,
    },
    "modules": ["custom/right-sep", "tray"],
  },
}
