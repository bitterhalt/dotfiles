# Generated by pywal16
font: Adwaita Mono, Symbols Nerd Font Mono 13
background: "{background}f0" # 'f0' adds a slight alpha transparency if desired, or just use "{background}"
color: "{foreground}"
border: "{color1}"
separator: " ➜ "
border_width: 1
corner_r: 4
padding: 20
rows_per_column: 3
column_padding: 25

anchor: top
margin_right: 16
margin_bottom: 16
margin_left: 16
margin_top: 16

inhibit_compositor_keyboard_shortcuts: true
auto_kbd_layout: true

menu:
  - key: "a"
    desc: Apps
    submenu:
      - key: "a"
        desc: All
        cmd: zen-browser|discord|thunderbird|transmission-gtk
      - key: "b"
        desc: Browser
        cmd: zen-browser
      - key: "d"
        desc: Discord
        cmd: discord
      - key: "m"
        desc: Email
        cmd: thunderbird
      - key: "t"
        desc: Torrent
        cmd: transmission-gtk
      - key: "g"
        desc: Gaming
        submenu:
          - key: "a"
            desc: "All"
            cmd: steam|lutris
          - key: "s"
            desc: Steam
            cmd: steam
          - key: "l"
            desc: Lutris
            cmd: lutris

  - key: "c"
    desc: Connections
    submenu:
      - key: "a"
        desc: 󰓃 Audio devices
        cmd: fuzzel_sound
      - key: "b"
        desc: 󰂯 Bluetooth [Bluetui]
        cmd: foot -a bluetui -e bluetui
      - key: "w"
        desc: 󰖩 Wi-Fi (Impala)
        cmd: foot -a impala -e impala
      - key: "n"
        desc: 󰲝 Network Manager
        cmd: nm-connection-editor

  - key: "n"
    desc: Notes
    submenu:
      - key: "s"
        desc: 󰍉 Search
        cmd: fuzzel_notes -s
      - key: "n"
        desc: 󰎚 New Note
        cmd: fuzzel_notes -c
      - key: "t"
        desc:  TODO
        cmd: footclient -a noteterm -T Notes sh -c "cd ~/Documents/personal/notes/ && nvim todo.md"
      - key: "d"
        desc: 󰩹 Delete
        cmd: fuzzel_notes -d

  - key: "p"
    desc: Pacman
    submenu:
      - key: "i"
        desc: Install
        cmd: foot -a pacseek -T pacseek -e pacseek -m
      - key: "u"
        desc: Update
        cmd: foot -a pop-upgrade -e sys_upgrade

  - key: "x"
    desc: Power
    submenu:
      - key: "l"
        desc: Lock
        cmd: swaylock -C ~/.cache/wal/colors-swaylock
      - key: "e"
        desc: Logout
        cmd: niri msg action quit
      - key: "z"
        desc: Sleep 💤
        cmd: systemctl suspend
      - key: "S"
        desc: Shutdown
        cmd: systemctl poweroff
      - key: "R"
        desc: Reboot
        cmd: systemctl reboot
      - key: "U"
        desc: Reboot UEFI
        cmd: systemctl reboot --firmware-setup

  - key: "r"
    desc: Recording
    submenu:
      - key: "1"
        desc: 󰑋 Record Screen
        cmd: wl-record -f
      - key: "2"
        desc: 󰩬 Record Regional
        cmd: wl-record -r
      - key: "3"
        desc: 󰄀 Screenshot Full Screen
        cmd: wl-shot -f
      - key: "4"
        desc: 󰩬 Screenshot Regional
        cmd: wl-shot -re
      - key: "5"
        desc: 󰵸 Regional Gif
        cmd: foot -a "wl-record-gif" -e gif_rec

  - key: "s"
    desc: Settings
    submenu:
      - key: "b"
        desc: Bash
        cmd: foot -e nvim ~/.bashrc ~/.config/shell/aliases ~/.config/shell/inputrc
      - key: "d"
        desc: Fuzzel
        cmd: foot -e nvim ~/.config/fuzzel/fuzzel.ini
      - key: "f"
        desc: Foot
        cmd: foot -e nvim ~/.config/foot/foot.ini
      - key: "k"
        desc: Wlr-which-key
        cmd: foot sh -c "cd ~/.config/wlr-which-key/ && nvim *"
      - key: "n"
        desc: Niri
        cmd: foot sh -c "cd ~/.config/niri/ && vopen ."
      - key: "p"
        desc: "Pywal"
        cmd: foot -e nvim ~/.local/bin/setbg  ~/.config/wal/templates/*
      - key: "v"
        desc: Nvim
        cmd: foot sh -c "cd ~/.config/nvim && vopen ."
      - key: "w"
        desc: Waybar
        cmd: foot sh -c "cd ~/.config/waybar/ && vopen ."
      - key: "m"
        desc: Monitor
        submenu:
          - key: "a"
            desc: Atop
            cmd: foot -T atop -e amdgpu_top --smi
          - key: "b"
            desc: Btop
            cmd: foot -a btop -e btop
          - key: "l"
            desc: Logs
            cmd: foot -a foot -T journalctl -e journalctl -f
          - key: "c"
            desc: Combined [ tmux-window ]
            cmd: foot -a Sysmon -T Sysmon -e ~/.local/bin/tmux-sysmon.sh

  - key: "t"
    desc: Theming
    submenu:
      - key: "w"
        desc: Set wallpaper
        cmd: swayimg --class swayimg-setwall -g ~/Pictures/wallpaper/
      - key: "t"
        desc: Set theme
        cmd: fuzzel_theme
      - key: "s"
        desc: Save theme
        cmd: fuzzel_theme -s
