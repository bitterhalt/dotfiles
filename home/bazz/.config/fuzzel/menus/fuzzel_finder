#!/usr/bin/env bash

# Fuzzel file finder using fd

DMENU="fuzzel -d -a top --y 24 -l 10 --minimal-lines"

EDITOR="nvim"

QUERY=$($DMENU -w 25 --placeholder="Find files ")
[[ -z "$QUERY" ]] && exit 0

SELECTION=$(
  fd -HI -t f \
    --exclude Pictures \
    --exclude Videos \
    --exclude bin \
    --exclude lib \
    --exclude lib64 \
    --exclude man \
    "$QUERY" \
    "$HOME" \
    /etc \
    /usr \
    /opt \
    /var \
    /srv \
    2>/dev/null |
    while IFS= read -r file; do
      [[ -L "$file" ]] && continue
      printf '%s\n' "$file"
    done |
    $DMENU -w 55 --placeholder="Select file "
)

if [[ -n "$SELECTION" ]]; then
  MIME=$(file --mime-type -b "$SELECTION")

  if [[ "$MIME" == text/* ||
    "$SELECTION" == *.sh ||
    "$SELECTION" == *.py ||
    "$SELECTION" == *.conf ]]; then

    if [[ "$SELECTION" == "$HOME"* ]]; then
      "$TERMINAL" -e "$EDITOR" "$SELECTION" &
    else
      "$TERMINAL" -e pkexec "$EDITOR" "$SELECTION" &
    fi
  else
    xdg-open "$SELECTION" &
  fi

  disown
fi
