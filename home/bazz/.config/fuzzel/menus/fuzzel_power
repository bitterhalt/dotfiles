#!/usr/bin/env bash

set -euo pipefail

FUZZEL_FLAGS="-d -a top --y 8 -w 20 --minimal-lines"

confirm_action() {
  local action_name="$1"
  local selection
  selection=$(echo -e "n ➜ No, Cancel\ny ➜ Yes, ${action_name}" | fuzzel $FUZZEL_FLAGS)
  if [[ "$selection" == *"Yes"* ]]; then
    return 0
  fi
  return 1
}

while true; do
  SUB=$(echo -e "1 ➜ Lock\n2 ➜ Exit\n3 ➜ zZzz 💤\n4 ➜ Shutdown\n5 ➜ Reboot\n6 ➜ Reboot UEFI" | fuzzel $FUZZEL_FLAGS)

  if [ -z "$SUB" ]; then
    exit 0
  fi

  case "$SUB" in
  *"Lock")
    swaylock -C ~/.cache/wal/colors-swaylock
    exit 0
    ;;
  *"Exit")
    niri msg action quit
    exit 0
    ;;
  *"zZzz"*)
    systemctl suspend
    exit 0
    ;;
  *"Shutdown")
    confirm_action "Shutdown" && systemctl poweroff
    exit 0
    ;;
  *"Reboot")
    confirm_action "Reboot" && systemctl reboot
    exit 0
    ;;
  *"Reboot UEFI")
    confirm_action "Reboot to UEFI" && systemctl reboot --firmware-setup
    exit 0
    ;;
  esac
done
