include=~/.config/mako/rules.conf

# SETTINGS
format=<b>%s</b>\n\n%b
font=Adwaita Sans, Symbols Nerd Font Mono 11
icons=1
default-timeout=5000
ignore-timeout=0
icon-path=/home/bazz/.local/share/icons/Papirus-Dark/
layer=overlay
sort=-time

# STYLE
anchor=top-center
border-radius=4
border-size=1
height=400
margin=24
max-history=20
max-icon-size=48
padding=15
width=300

# COLORS
background-color=#100f0f
border-color=#1C1B1A
progress-color=#403E3C
text-color=#CECDC3

# URGENCY LEVELS
[urgency=high]
background-color=#100f0f
border-color=#af3029
default-timeout=0
text-color=#ad8301
