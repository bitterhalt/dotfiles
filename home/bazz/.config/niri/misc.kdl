cursor {
  xcursor-theme "Bibata-Modern-Classic"
  xcursor-size 24
  hide-after-inactive-ms 10000
}

hotkey-overlay {
  skip-at-startup
}

prefer-no-csd
screenshot-path "~/Pictures/Screenshots/%Y-%m-%d-%H-%M-%S.png"

gestures {
  hot-corners {
    off
  }
}

overview {
  zoom 0.40
  backdrop-color "#1C1B1A"
  workspace-shadow {
    color "#00000070"
    softness 30
    spread 5
    offset x=0 y=5
  }
}

