#!/usr/bin/env bash
set -e

declare -A desc_to_id
devices=()
current_device_display=""
current_id=$(wpctl status | grep -A 5 "Sinks:" | grep "*" | awk '{print $3}' | tr -d '.')

while IFS=$'\t' read -r id desc; do
  display="$desc"

  if [[ "$id" == "$current_id" ]]; then
    display="󰄬  $display"
    current_device_display="$display"
  else
    devices+=("$display")
  fi

  desc_to_id["$display"]="$id"
done < <(pw-dump Node | jq -r '
  .[]
  | select(.info.props["media.class"] == "Audio/Sink")
  | [
      (.id | tostring),
      .info.props["node.description"]
    ]
  | @tsv
')

final_list=()
[[ -n "$current_device_display" ]] && final_list+=("$current_device_display")

mapfile -t sorted_devices < <(printf '%s\n' "${devices[@]}" | sort)
final_list+=("${sorted_devices[@]}")

# 4. Show Menu
selected=$(printf '%s\n' "${final_list[@]}" | fuzzel -d -a top --y 8 -w 55 --minimal-lines --placeholder "Switch the audio device: ")

[ -z "$selected" ] && exit 0

id="${desc_to_id[$selected]}"
[ -z "$id" ] && exit 0

wpctl set-default "$id"
notify-send -t 5000 "Audio notify" "Audio device changed to:\n$selected"
