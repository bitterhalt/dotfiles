#!/usr/bin/env bash

HISTORY_FILE="$HOME/.cache/fuzzel-runhistory"
PROMPT="fuzzel -d --line-height 26"

history_list=$(tac "$HISTORY_FILE" | awk '!seen[$0]++' | head -n 5)

all_binaries=$(echo "$PATH" | tr ':' '\n' | xargs -I {} find {} -maxdepth 1 -executable -type f 2>/dev/null | awk -F/ '{print $NF}' | sort -u)
filtered_binaries=$(echo "$all_binaries" | grep -vFx -f <(echo "$history_list"))

choice=$(printf "%s\n%s" "$history_list" "$filtered_binaries" | sed '/^$/d' | $PROMPT)

if [ -n "$choice" ]; then
  echo "$choice" >>"$HISTORY_FILE"
  setsid "$choice" >/dev/null 2>&1 &
fi
