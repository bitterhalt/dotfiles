#!/usr/bin/env bash

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
RESET="\033[0m"

echo -e "${CYAN}[*] Beginning system upgrade...${RESET}"

if [ -f /etc/os-release ]; then
  . /etc/os-release
  echo -e "${CYAN}[*] Detected OS: $NAME${RESET}"

  case "$ID" in
  arch | manjaro | cachyos | endeavouros)
    if command -v yay &>/dev/null; then
      echo -e "${CYAN}[*] Updating via yay...${RESET}"
      MAIN_UPGRADE_CMD="yay -Syu"
    else
      echo -e "${CYAN}[*] Updating via pacman...${RESET}"
      MAIN_UPGRADE_CMD="sudo pacman -Syu"
    fi
    ;;
  void)
    echo -e "${CYAN}[*] Updating via xbps...${RESET}"
    MAIN_UPGRADE_CMD="sudo xbps-install -Syu"
    ;;
  ubuntu | debian | pop | mint)
    echo -e "${CYAN}[*] Updating via apt...${RESET}"
    MAIN_UPGRADE_CMD="sudo apt update && sudo apt dist-upgrade -y"
    ;;
  fedora | rhel | centos)
    echo -e "${CYAN}[*] Updating via dnf...${RESET}"
    MAIN_UPGRADE_CMD="sudo dnf upgrade -y"
    ;;
  *)
    echo -e "${YELLOW}[!] Generic Linux detected. Attempting to use pacman/yay...${RESET}"
    if command -v yay &>/dev/null; then
      MAIN_UPGRADE_CMD="yay -Syu"
    else
      MAIN_UPGRADE_CMD="sudo pacman -Syu"
    fi
    ;;
  esac
else
  echo -e "${RED}[x] Cannot determine OS type (/etc/os-release missing). Defaulting to yay...${RESET}"
  MAIN_UPGRADE_CMD="yay -Syu"
fi

if eval "$MAIN_UPGRADE_CMD"; then
  echo -e "\n${GREEN}[✓] Base system upgrade complete!${RESET}"
else
  echo -e "\n${RED}[x] Base system upgrade failed! Check the errors above.${RESET}"
fi

echo -e "\n${CYAN}[*] Checking for universal package managers...${RESET}"

if command -v snap &>/dev/null; then
  echo -e "${CYAN}[*] Snap detected. Updating snap packages...${RESET}"
  if sudo snap refresh; then
    echo -e "${GREEN}[✓] Snap packages updated successfully!${RESET}"
  else
    echo -e "${RED}[x] Snap update encountered an error.${RESET}"
  fi
fi

if command -v flatpak &>/dev/null; then
  echo -e "\n${CYAN}[*] Flatpak detected. Updating flatpak packages...${RESET}"
  if flatpak update -y; then
    echo -e "${GREEN}[✓] Flatpak packages updated successfully!${RESET}"
  else
    echo -e "${RED}[x] Flatpak update encountered an error.${RESET}"
  fi
fi

echo -e "\nPress <Enter> to exit this window."
read -r _
