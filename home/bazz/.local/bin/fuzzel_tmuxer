#!/usr/bin/env bash

sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null)

if [ -n "$sessions" ]; then
  menu_options="Attach session\nNew session\nDelete session"
else
  menu_options="New session"
fi

choice=$(echo -e "$menu_options" |
  fuzzel -d -a top --y 6 --x 6 -w 25 --minimal-lines --placeholder "Tmux manager:")

case "$choice" in
"Attach session")
  target=$(echo "$sessions" | fuzzel -d -a top --y 6 --x 6 -w 25 --minimal-lines --placeholder "Attach to:")
  [ -n "$target" ] && "$TERMINAL" -e tmux attach-session -t "$target"
  ;;

"New session")
  session_name=$(echo "" | fuzzel -d -a top --y 6 --x 6 -w 25 --minimal-lines --placeholder "Name (optional):")
  if [ -z "$session_name" ]; then
    "$TERMINAL" -e tmux new-session
  else
    "$TERMINAL" -e tmux new-session -s "$session_name"
  fi
  ;;

"Delete session")
  target=$(echo "$sessions" | fuzzel -d -a top --y 6 --x 6 -w 25 --minimal-lines --placeholder "Kill session:")

  if [ -n "$target" ]; then
    confirm=$(echo -e "Yes\nNo" | fuzzel -d -a top --y 6 --x 6 -w 25 --minimal-lines --placeholder "Delete $target?")

    if [ "$confirm" = "Yes" ]; then
      tmux kill-session -t "$target"
    fi
  fi
  ;;
esac
