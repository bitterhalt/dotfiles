#!/usr/bin/env bash

BGCOL="121212"
WALL_DIR="$HOME/.local/share/wall"
LOCKSCREEN="$WALL_DIR/lockscreen.png"

mkdir -p "$WALL_DIR"

get_backend() {
  printf "wal\ncolorthief" | fuzzel -d --minimal-lines --placeholder "Select Backend: " || echo "wal"
}

is_niri() {
  command -v niri >/dev/null 2>&1 && niri msg outputs >/dev/null 2>&1
}

_apply_wallpaper() {
  local path="$1"

  if [[ ! -f "$path" ]]; then
    echo "Error: '$path' does not exist." >&2
    return 1
  fi

  awww img "$path" --transition-type=none

  if is_niri; then
    gm convert "$path" -blur 0x30 -modulate 80 "$LOCKSCREEN"
    awww img -n overview "$LOCKSCREEN" --transition-type=none
  fi
}

setwall() {
  _apply_wallpaper "$1"
}

pywal() {
  local backend=$(get_backend)
  _apply_wallpaper "$1" || return 1
  wal -n --backend "$backend" -i "$1"
  refresh_portals.sh
}

pywal_fixed() {
  local backend=$(get_backend)
  _apply_wallpaper "$1" || return 1
  wal -n --backend "$backend" -b "$BGCOL" -i "$1"
  refresh_portals.sh
}

case "$1" in
-w)
  shift
  setwall "$1"
  ;;
-p)
  shift
  pywal "$1"
  ;;
-pf)
  shift
  pywal_fixed "$1"
  ;;
*) echo "Usage: $0 {-w|-p|-pf} <path_to_image>" ;;
esac
