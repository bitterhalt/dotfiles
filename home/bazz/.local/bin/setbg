#!/usr/bin/env bash

BGCOL="121212"

get_backend() {
  local backend
  backend=$(printf "wal\ncolorthief" | fuzzel -d --minimal-lines --placeholder "Select Backend: ")
  if [[ -z "$backend" ]]; then
    backend="wal"
  fi
  echo "$backend"
}

get_resolution() {
  if ! command -v wlr-randr >/dev/null 2>&1; then
    echo "Error: wlr-randr is not installed." >&2
    return 1
  fi

  local out
  out=$(wlr-randr | awk '
    /^[^[:space:]]/ { enabled = 0 }
    /Enabled: yes/ { enabled = 1 }
    /current/ {
      if (enabled && match($0, /[0-9]+x[0-9]+/)) {
        split(substr($0, RSTART, RLENGTH), r, "x")
        print r[1], r[2]
        exit
      }
    }
  ')

  if [[ -n "$out" ]]; then
    local res=($out)
    local w="${res[0]}"
    local h="${res[1]}"

    local is_niri="false"
    if pgrep -x niri >/dev/null 2>&1; then
      is_niri="true"
    fi

    echo "$w $h $is_niri"
    return 0
  fi

  return 1
}

_apply_wallpaper() {
  local path="$1"

  [[ -f "$path" ]] || {
    echo "Error: '$path' does not exist." >&2
    return 1
  }

  local res_data
  res_data=$(get_resolution) || {
    echo "Error: failed to detect resolution." >&2
    return 1
  }

  local res=($res_data)
  local w="${res[0]}"
  local h="${res[1]}"
  local is_niri="${res[2]}"

  local dir="$HOME/.local/share/wall/"
  local out="${dir}wallpaper.png"
  local lockscreen="${dir}lockscreen.png"

  mkdir -p "$dir"

  vipsthumbnail "$path" \
    --size "${w}x${h}" \
    --output "$out" || return 1

  awww img "$out" --transition-type=any \
    --transition-step=60 \
    --transition-fps=60 \
    --transition-duration=.7

  if [[ "$is_niri" == "true" ]]; then
    gm convert "$out" -blur 0x55 -modulate 80 "$lockscreen"
    awww img -n overview "$lockscreen" --transition-type=none
  fi
}

setwall() {
  _apply_wallpaper "$1"
}

pywal() {
  local backend
  backend=$(get_backend)

  _apply_wallpaper "$1" || return 1
  wal -n --backend "$backend" -i "$HOME/.local/share/wall/wallpaper.png"
  refresh_portals.sh
}

pywal_fixed() {
  local backend selection custom_bg
  backend=$(get_backend)

  selection=$(printf "121212 (Default)\n000000 (Pure Black)" |
    fuzzel -d --minimal-lines --placeholder "Type or select background hex (e.g. 1A1A1A): ")

  custom_bg=$(echo "$selection" | awk '{print $1}' | tr -d '#')

  if [[ -z "$custom_bg" ]]; then
    custom_bg="$BGCOL"
  fi

  _apply_wallpaper "$1" || return 1
  wal -n --backend "$backend" -b "$custom_bg" -i "$HOME/.local/share/wall/wallpaper.png"
  refresh_portals.sh
}

case "$1" in
-w)
  shift
  setwall "$1"
  ;;
-p)
  shift
  pywal "$1"
  ;;
-pf)
  shift
  pywal_fixed "$1"
  ;;
*)
  echo "Usage: $0 {-w|-p|-pf} path/to/wallpaper"
  exit 1
  ;;
esac
