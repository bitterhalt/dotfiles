#!/usr/bin/env bash

pacman_search() {
  pacman -Slq | fzf --multi --border-label "pacman-install" --preview 'pacman -Si {1}' | xargs -ro sudo pacman -S
}

aur_search() {
  local helper="$1"

  (
    "$helper" -Slq
    "$helper" -Slq aur
  ) | fzf --multi --border-label "$helper-install" --preview "$helper -Si {1}" | xargs -ro "$helper" -S --noconfirm
}

if command -v paru &>/dev/null; then
  AUR_HELPER="paru"
elif command -v yay &>/dev/null; then
  AUR_HELPER="yay"
else
  AUR_HELPER=""
fi

case "$1" in
-y)
  if [ -n "$AUR_HELPER" ]; then
    aur_search "$AUR_HELPER"
  else
    echo "Error: Neither paru nor yay was found. Falling back to pacman (no AUR)." >&2
    pacman_search
  fi
  ;;
*)
  if [ -n "$1" ]; then
    echo "Unknown option: $1"
    echo "Usage: ${0##*/} [-y]"
    exit 1
  fi
  pacman_search
  ;;
esac
