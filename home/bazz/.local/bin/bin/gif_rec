#!/usr/bin/env bash

set -e

SAVEDIR="${HOME}/Videos/Captures"
TIMESTAMP=$(date +'%Y-%m-%d-%H-%M-%S')
FINAL_GIF="$SAVEDIR/${TIMESTAMP}_capture.gif"
TEMP_MP4="${HOME}/.cache/${TIMESTAMP}_temp.mp4"

mkdir -p "$SAVEDIR"
echo "Select a region on your screen..."

REGION=$(slurp -f "%wx%h+%x+%y")

if [ -z "$REGION" ]; then
  echo "Selection cancelled."
  exit 1
fi

cleanup() {
  echo -e "\n[!] Recording caught stop signal. Finalizing video..."
  sleep 1
  if [ -f "$TEMP_MP4" ]; then
    echo "Processing GIF colors (please wait)..."
    ffmpeg -v error -i "$TEMP_MP4" -vf "fps=30,scale=iw:-1:flags=lanczos,palettegen" -y /tmp/gif_palette.png
    ffmpeg -v error -i "$TEMP_MP4" -i /tmp/gif_palette.png -filter_complex "fps=30,scale=iw:-1:flags=lanczos[x];[x][1:v]paletteuse" -y "$FINAL_GIF"
    rm -f /tmp/gif_palette.png
    rm -f "$TEMP_MP4"
    echo "Done! Saved to $FINAL_GIF"
  fi
  exit 0
}

trap cleanup SIGINT SIGTERM
echo "----------------------------------------"
echo "🔴 RECORDING REGION..."
echo "Close this window or press Ctrl+C to STOP."
echo "----------------------------------------"
gpu-screen-recorder -w "$REGION" -f 30 -o "$TEMP_MP4"
