########################
# wm independent hotkeys
########################

# terminal emulator
super + Return
	xfce4-terminal

# program launcher
super + d
	~/.config/rofi/applauncher/rofidmenu2
# Rofi window
alt + t
	~/.config/rofi/applauncher/rofiwindow

# power-menu
super + shift + p
     $HOME/.config/rofi/powermenu/powermenu3

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

# Launch Apps
super shift + {e,w,m,d}
	{thunar,firefox,thunderbird,discord}

super + shift + Delete
	bspc rule -a \* -o state=floating && $TERMINAL -e htop

###############
# bspwm hotkeys
###############

# quit/restart bspwm
super + alt + {q,r}
	bspc {quit,wm -r}

# close and kill
super + {_,shift + }q
	bspc node -{c,k}

# swap the current node and the biggest window
super + g
	bspc node -s biggest.window

super + ctrl + i
	$HOME/scripts/sysnfo

super + ctrl + w
	$home/scripts/weather


###########
# preselect
###########

# Move current window to a pre-selected node
super + shift + y
    bspc node -n last.!automatic

# send the newest marked node to the newest preselected node
super + y
	bspc node newest.marked.local -n newest.!automatic.local

# preselect the direction
super + ctrl + {h,j,k,l}
	bspc node -p {west,south,north,east}

# preselect the ratio
super + ctrl + {1-9}
	bspc node -o 0.{1-9}

# cancel the preselection for the focused node
super + ctrl + space
	bspc node -p cancel

# cancel the preselection for the focused desktop
super + ctrl + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel


#############
# state/flags
#############

#Toggle between fullscreen and tiled
super + f
	bspc node --state \~fullscreen

# Toggle beetwen floating & tiled
super + shift + space
     bspc node -t \~floating

# set the window state
super + {t,shift + t,s}
	bspc node -t {tiled,pseudo_tiled,floating}

# Toggle between the tiled and monocle layout
super + m
	bspc desktop -l next

# set the node flags
super + ctrl + {m,x,y,z}
	bspc node -g {marked,locked,sticky,private
}

