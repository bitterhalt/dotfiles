cursor {
    xcursor-theme "Bibata-Modern-Classic"
    xcursor-size 24
    hide-after-inactive-ms 10000
}

hotkey-overlay {
    skip-at-startup
}

layout {
    background-color "#000000"
}

output "DP-1" {
    scale 1.0
    focus-at-startup
}

spawn-sh-at-startup "wlgreet; niri msg action quit --skip-confirmation"
