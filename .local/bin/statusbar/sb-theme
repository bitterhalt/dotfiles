#!/bin/sh

# Gruvbox colorscheme
color0="#1d2021" # black
color1="#cc241d" # Red
color2="#98971a" # green
color3="#d79921" # yellow
color4="#458588" # blue
color5="#b16286" # purple
color6="#689d6a" # green2
color7="#bdae93" # grey
color8="#928374" # gray2 
color9="#ebdbb2" # white
display() {
    args=""
    case $1 in
        -n) args="-n"; shift ;;
    esac

    if [ -n "${2+x}" ]; then
        color=$7
	else
		case "$(basename $0)" in
            sb-updates) color="$color5" ;;
            sb-cpu) color="$color7" ;;
            sb-memory) color="$color7" ;;
            sb-volume) color="$color5";;
            sb-date) color="$color4";;
            sb-network) color="$color7";;
            *) color="$color7" ;;
        esac
    fi
    echo $args "^c$color^$1"
}
