#!/bin/sh

case $BLOCK_BUTTON in
	1) pavucontrol ; pkill -RTMIN+10 "${STATUSBAR:-dwmblocks}" ;;
	2) pactl set-sink-mute @DEFAULT_SINK@ toggle ;;
    6) "$TERMINAL" -e "$EDITOR" "$0" ;;
esac
. sb-theme
if [ "$(pamixer --get-mute)" = true ]; then
    display "Mute "
    exit
fi

vol="$(pamixer --get-volume)"
[ $? -ne 0 ] && [ -z "$vol" ] && exit 1

case 1 in
	$((vol >= 30)) ) icon=" " ;;
	$((vol >= 15)) ) icon=" " ;;
	$((vol >= 1)) ) icon=" " ;;
	* ) display Mute && exit ;;
esac

display "$icon^d^$vol%"
