#!/bin/sh

case $BLOCK_BUTTON in
	1) st -c floatterm -e pulsemixer ;;
	2) wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle ;;
esac

vol="$(wpctl get-volume @DEFAULT_AUDIO_SINK@)"

[ "$vol" != "${vol%\[MUTED\]}" ] && echo ´æĞ && exit

vol="${vol#Volume: }"

split() {
	IFS=$2
	set -- $1
	printf '%s' "$@"
}

vol="$(printf "%.0f" "$(split "$vol" ".")")"

case 1 in
	$((vol >= 30)) ) icon="´Ç¿ " ;;
	$((vol >= 15)) ) icon="´Çğ " ;;
	$((vol >= 1)) ) icon="´ÇĞ " ;;
	* ) echo ´æĞ && exit ;;
esac
. sb-theme
display "$icon$vol%"
