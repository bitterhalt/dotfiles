#!/bin/sh

ARCHIVE="DWM
ST
DMENU
DWMBLOCKS
PICOM"
DMENUCHOICE=$(printf "$ARCHIVE" | dmenu -l 6 -p "EDIT:")

case $DMENUCHOICE in
    DWM) $TERMINAL -e nvim   ~/Documents/suckless/dwm/config.def.h ;;
    ST) $TERMINAL -e nvim ~/Documents/suckless/st/config.def.h ;;
    DMENU) $TERMINAL -e nvim ~/Documents/suckless/dmenu/config.def.h ;;
    DWMBLOCKS) $TERMINAL -e nvim ~/Documents/suckless/dwmblocks-async/config.c ;;
    PICOM) $TERMINAL -e nvim ~/.config/picom.conf ;;

esac
