#!/bin/bash

options=("Reboot" "Shutdown" "Suspend" "Lock" "Lockout")
selected=$(printf '%s\n' "${options[@]}" | dmenu -i -p "Power Options:")

if [[ -n "$selected" ]]; then
    case "$selected" in
        "Reboot")
            confirm=$(echo -e "Yes\nNo" | dmenu -i -p "Are you sure you want to reboot?")
            if [[ "$confirm" == "Yes" ]]; then
                systemctl reboot
            fi
            ;;
        "Shutdown")
            confirm=$(echo -e "Yes\nNo" | dmenu -i -p "Are you sure you want to shutdown?")
            if [[ "$confirm" == "Yes" ]]; then
                systemctl poweroff
            fi
            ;;
        "Suspend")
            confirm=$(echo -e "Yes\nNo" | dmenu -i -p "Are you sure you want to suspend?")
            if [[ "$confirm" == "Yes" ]]; then
                systemctl suspend
            fi
            ;;
        "Lock")
            i3lock-color
            ;;
        "Lockout")
            confirm=$(echo -e "Yes\nNo" | dmenu -i -p "Are you sure you want to lock the screen and logout?")
            if [[ "$confirm" == "Yes" ]]; then
                if [[ "$DESKTOP_SESSION" == 'openbox' ]]; then
                    openbox --exit
                elif [[ "$DESKTOP_SESSION" == 'bspwm' ]]; then
                    bspc quit
                elif [[ "$DESKTOP_SESSION" == 'i3' ]]; then
                    i3-msg exit
                elif [[ "$DESKTOP_SESSION" == 'dwm' ]]; then
                    pkill -9 dwm
                elif [[ "$DESKTOP_SESSION" == 'plasma' ]]; then
                    qdbus org.kde.ksmserver /KSMServer logout 0 0 0
                else
                    echo "Unsupported desktop environment: $DESKTOP_SESSION"
                fi
            fi
            ;;
    esac
fi



