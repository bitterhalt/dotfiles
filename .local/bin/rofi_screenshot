#!/usr/bin/env bash

# rofi theme
THEME="$HOME/.config/rofi/rofi_screenrecord/theme.rasi"

get_options() {
  echo "’ĆĮ  Record Screen (MP4)"
  echo "’ĆĮ  Record Screen (MP4+Audio)"
  echo "’ĆĮ  Record Region (MP4)"
  echo "’Ć░  Screenshot Full"
  echo "’Ć░  Screenshot Region"
  echo "’Ć░  Screenshot Full+delay"
  echo "’ŗō  Stop Recording"
}

main() {

  # Get choice from rofi
  choice=$( (get_options) | rofi -dmenu -i -fuzzy -p "Capture" -theme "$THEME")

  # If user has not picked anything, exit
  if [[ -z "${choice// /}" ]]; then
    exit 1
  fi

  # run the selected command
  case $choice in
  '’ĆĮ  Record Screen (MP4)')
    quick-record -v
    ;;
  '’ĆĮ  Record Screen (MP4+Audio)')
    quick-record -sc
    ;;
   '’ĆĮ  Record Region (MP4)')
    quick-record -r
    ;;
   '’Ć░  Screenshot Full' )
    quick-shot -f
    ;;
  '’Ć░  Screenshot Region')
    quick-shot -s
    ;;
   '’Ć░  Screenshot Full+delay')
    quick-shot -t 3
    ;;
  '’ŗō  Stop Recording')
    quick-record -kill
    ;;
  esac

  # done
  set -e
}

main &

exit 0
